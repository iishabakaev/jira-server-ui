# --- core ---
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# --- database ---
DATABASE_URL=postgres://app:app@localhost:5432/jira_ui

# --- session / crypto ---
SESSION_COOKIE_NAME=jira_ui_sid
# 32 bytes base64 (run: openssl rand -base64 32)
JIRA_PAT_KEK=

# --- auth ---
AUTH_LOCAL_ENABLED=true
AUTH_LOCAL_ALLOW_SIGNUP=false
AUTH_KEYCLOAK_ENABLED=false
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
ROLE_GROUP_MAP={}

# --- jira ---
JIRA_BASE_URL=
JIRA_WEBHOOK_SECRET=
JIRA_MAX_RPS=6
JIRA_MAX_BURST=12
JIRA_MAX_CONCURRENCY=8

# --- sync ---
SYNC_DEFAULT_WINDOW_DAYS=365

# --- observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
EXPOSE_OPENAPI=true
